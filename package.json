{
	"name": "pi-cursor-herdr-subagents",
	"version": "0.1.0",
	"description": "Manage interactive Cursor ACP subagents from Pi, with each session visualized in a Herdr event-viewer tab.",
	"type": "module",
	"license": "MIT",
	"author": "Boston Cartwright",
	"keywords": [
		"pi-package",
		"pi-extension",
		"pi",
		"cursor",
		"acp",
		"herdr",
		"subagent"
	],
	"homepage": "https://github.com/bstncartwright/pi-cursor-herdr-subagents#readme",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/bstncartwright/pi-cursor-herdr-subagents.git"
	},
	"bugs": {
		"url": "https://github.com/bstncartwright/pi-cursor-herdr-subagents/issues"
	},
	"files": [
		"extensions",
		"README.md",
		"LICENSE"
	],
	"publishConfig": {
		"access": "public"
	},
	"pi": {
		"extensions": [
			"./extensions/index.ts"
		]
	},
	"scripts": {
		"check": "npm run typecheck && npm test",
		"typecheck": "tsc --noEmit",
		"test": "node --test --experimental-strip-types test/*.test.ts"
	},
	"peerDependencies": {
		"@earendil-works/pi-ai": "*",
		"@earendil-works/pi-coding-agent": "*",
		"@earendil-works/pi-tui": "*",
		"typebox": "*"
	},
	"peerDependenciesMeta": {
		"@earendil-works/pi-ai": { "optional": true },
		"@earendil-works/pi-coding-agent": { "optional": true },
		"@earendil-works/pi-tui": { "optional": true },
		"typebox": { "optional": true }
	},
	"devDependencies": {
		"@earendil-works/pi-ai": "0.80.6",
		"@earendil-works/pi-coding-agent": "0.80.6",
		"@earendil-works/pi-tui": "0.80.6",
		"@types/node": "^24.10.0",
		"typebox": "1.1.38",
		"typescript": "^5.9.3"
	},
	"engines": {
		"node": ">=22"
	}
}
